FROM python:3.13-slim
RUN apt-get update && apt-get install -y curl git && rm -rf /var/lib/apt/lists/*
WORKDIR /app
ARG GIT_REF=origin/final
COPY . /repo
RUN git -C /repo archive ${GIT_REF} common services/account-service | tar -x -C /app && \
    mv /app/services/account-service/* /app/ && rm -rf /app/services /repo
RUN pip install --no-cache-dir -r /app/common/requirements.txt
EXPOSE 8002
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8002", "--proxy-headers", "--forwarded-allow-ips=*"]
